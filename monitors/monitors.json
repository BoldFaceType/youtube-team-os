{
  "monitors": [
    {
      "id": "content-calendar-deadlines",
      "description": "Warn when a project's target publish date is within 3 days and stage is not PUBLISH or POSTMORTEM",
      "trigger": "SessionStart",
      "command": "node \"${CLAUDE_PLUGIN_ROOT}/monitors/check-deadlines.js\"",
      "timeout": 10,
      "failureMode": "warn"
    },
    {
      "id": "stale-inbox",
      "description": "Warn when any role inbox has items older than 7 days without stage progression",
      "trigger": "SessionStart",
      "command": "node \"${CLAUDE_PLUGIN_ROOT}/monitors/check-stale-inbox.js\"",
      "timeout": 10,
      "failureMode": "warn"
    },
    {
      "id": "postmortem-due",
      "description": "Remind when a published video is 28–32 days old and postmortem.md is still a stub",
      "trigger": "SessionStart",
      "command": "node \"${CLAUDE_PLUGIN_ROOT}/monitors/check-postmortem-due.js\"",
      "timeout": 10,
      "failureMode": "warn"
    }
  ]
}
